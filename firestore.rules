rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default safety net (deny all read/writes by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check valid document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Explicitly allow operations on collections used by the client application
    match /users/{userId} {
      allow read, write: if true;
    }
    match /branches/{branchId} {
      allow read, write: if true;
    }
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
    match /inventory/{itemId} {
      allow read, write: if true;
    }
    match /recipes/{recipeId} {
      allow read, write: if true;
    }
    match /menuCostingRecipes/{recipeId} {
      allow read, write: if true;
    }
    match /directPurchases/{purchaseId} {
      allow read, write: if true;
    }
    match /interBranchTransfers/{transferId} {
      allow read, write: if true;
    }
    match /wastageLogs/{logId} {
      allow read, write: if true;
    }
    match /breakageLogs/{logId} {
      allow read, write: if true;
    }
    match /shifts/{shiftId} {
      allow read, write: if true;
    }
    match /shiftExpenses/{expenseId} {
      allow read, write: if true;
    }
    match /sales/{saleId} {
      allow read, write: if true;
    }
    match /kdsOrders/{orderId} {
      allow read, write: if true;
    }
    match /productionReports/{reportId} {
      allow read, write: if true;
    }
    match /rndLogs/{logId} {
      allow read, write: if true;
    }
    match /complimentaries/{logId} {
      allow read, write: if true;
    }
    match /cafeteriaReports/{reportId} {
      allow read, write: if true;
    }
    match /attendance/{recordId} {
      allow read, write: if true;
    }
    match /loans/{loanId} {
      allow read, write: if true;
    }
    match /reservations/{resId} {
      allow read, write: if true;
    }
    match /customers/{customerId} {
      allow read, write: if true;
    }
    match /budgets/{budgetId} {
      allow read, write: if true;
    }
    match /weddings/{weddingId} {
      allow read, write: if true;
    }
    match /corporates/{corporateId} {
      allow read, write: if true;
    }
    match /taxInfo/{taxId} {
      allow read, write: if true;
    }
    match /auditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
